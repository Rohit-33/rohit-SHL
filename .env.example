# Copy to .env and fill in. Any OpenAI-compatible chat-completions provider works.

# Groq (recommended: fast + generous free tier)
LLM_API_KEY=your-groq-api-key
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# OpenRouter alternative:
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# Gemini alternative (via its OpenAI-compat endpoint). Note: Gemini 2.5 models
# spend the completion token budget on hidden reasoning by default, which can
# starve the actual JSON output -- set LLM_REASONING_EFFORT=none to disable it.
# Groq rejects this field outright, so leave it unset for Groq.
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_MODEL=gemini-2.5-flash
# LLM_REASONING_EFFORT=none

LLM_TIMEOUT_SECONDS=20
